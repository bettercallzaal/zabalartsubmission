# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Neynar API Configuration
NEYNAR_API_KEY=your_neynar_api_key_here

# Neynar signer UUID for the ZABAL posting identity (used by
# /api/cron/zabal-daily-cast to publish to the /zao channel).
# Create at https://dev.neynar.com -> Signers -> approve with the
# Farcaster account you want ZABAL casts to come from.
NEYNAR_SIGNER_UUID=your_zabal_signer_uuid_here

# Farcaster Read API (optional - for failover)
FARCASTER_READ_API_BASE=https://haatz.quilibrium.com

# Cron Secret (for scheduled tasks)
CRON_SECRET=your_cron_secret_here
