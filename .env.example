# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Neynar API key - used ONLY for paid reads that haatz doesn't cover
# (vote-power Neynar score lookup, /zao cast counts). Writes go direct
# to a Hub via haatz (see ZABAL_* vars below).
NEYNAR_API_KEY=your_neynar_api_key_here

# ZABAL daily cron signer - pick ONE of the two options below.
#
# Option A (recommended, ~5 min setup): Neynar managed signer.
#   1. npx tsx scripts/generate-zabal-signer.ts
#   2. Tap Approve on the URL it prints in Warpcast (logged in as the
#      account that should post - bettercallzaal or thezao)
#   3. Set NEYNAR_SIGNER_UUID below to what the script prints
# Cron will publish via Neynar publish_cast using your approved signer.
NEYNAR_SIGNER_UUID=
#
# Option B (pure HAATZ, no Neynar for writes, ~15 min setup):
#   1. npx tsx scripts/generate-zabal-signer.ts --quilibrium
#   2. Follow the printed KeyGateway.add() on-chain steps via Etherscan
#   3. Set all three:
ZABAL_FID=
ZABAL_SIGNER_PRIVATE_KEY=
ZABAL_HUB_URL=https://haatz.quilibrium.com

# Farcaster Read API (optional - for failover)
FARCASTER_READ_API_BASE=https://haatz.quilibrium.com

# Cron Secret (for scheduled tasks)
CRON_SECRET=your_cron_secret_here
