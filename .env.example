# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Neynar API key - used ONLY for paid reads that haatz doesn't cover
# (vote-power Neynar score lookup, /zao cast counts). Writes go direct
# to a Hub via haatz (see ZABAL_* vars below).
NEYNAR_API_KEY=your_neynar_api_key_here

# ZABAL Farcaster signer for publishing casts directly via Hub (no
# Neynar dependency). One-time setup:
#   npx tsx scripts/generate-zabal-signer.ts
# Then approve the printed pubkey for the ZABAL account on Warpcast
# (Settings -> Add Custom Signer) and set these env vars.
ZABAL_FID=
ZABAL_SIGNER_PRIVATE_KEY=
# Snapchain Hub URL for cast submission. Defaults to Quilibrium's HAATZ
# Hypersnap proxy if unset.
ZABAL_HUB_URL=https://haatz.quilibrium.com

# Farcaster Read API (optional - for failover)
FARCASTER_READ_API_BASE=https://haatz.quilibrium.com

# Cron Secret (for scheduled tasks)
CRON_SECRET=your_cron_secret_here
